generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Uporabnik {
  id_uporabnik    Int             @id @default(autoincrement())
  ime             String          @db.VarChar(45)
  priimek         String          @db.VarChar(45)
  emso_crypted    String?         @db.VarChar(255)
  dostop          Int             @default(1)
  email           String          @unique @db.VarChar(100)
  geslo           String          @db.VarChar(255)
  voznje          Voznja[]
  urniki          Urnik[]
  gdpr_soglasje   Boolean         @default(false)
  gdpr_datum      DateTime?
  tahograf_zapisi TahografZapis[]
  logs            LOG_voznja[]
}

model Voznja {
  id_voznja       Int       @id @default(autoincrement())
  datum           DateTime  @db.Date
  zacetek         DateTime
  konc            DateTime
  trajanje        String?
  aktivnost       String?
  registerska     String?
  posadka         String?
  fk_uporabnik    Int
  timestamp_zapis DateTime?
  stranka         String?   @db.VarChar(100)
  relacija        String?   @db.VarChar(255)
  opis            String?   @db.VarChar(500)
  uporabnik       Uporabnik @relation(fields: [fk_uporabnik], references: [id_uporabnik])

  @@index([fk_uporabnik])
}

model TipVozila {
  id_tip_vozila Int      @id @default(autoincrement())
  naziv         String?  @db.VarChar(45)
  vozila        Vozilo[]

  @@map("tip_vozila")
}

model Vozilo {
  id_vozilo     Int       @id @default(autoincrement())
  registerska   String    @db.VarChar(45)
  st_sedezev    Int
  dolzina       Int?
  fk_tip_vozila Int
  tip_vozila    TipVozila @relation(fields: [fk_tip_vozila], references: [id_tip_vozila])
  urniki        Urnik[]

  @@index([fk_tip_vozila])
}

model Stranka {
  id_stranka Int     @id @default(autoincrement())
  naziv      String  @db.VarChar(45)
  email      String? @db.VarChar(45)
  telefonska String? @db.VarChar(45)
  davcna_st  Int?
  urniki     Urnik[]
}

model Urnik {
  id_urnik     Int       @id @default(autoincrement())
  datum        DateTime  @db.Date
  cena         Float?
  naziv        String?   @db.VarChar(45)
  placano      Boolean   @default(false)
  fk_vozilo    Int
  fk_uporabnik Int
  fk_stranka   Int
  vozilo       Vozilo    @relation(fields: [fk_vozilo], references: [id_vozilo])
  uporabnik    Uporabnik @relation(fields: [fk_uporabnik], references: [id_uporabnik])
  stranka      Stranka   @relation(fields: [fk_stranka], references: [id_stranka])

  @@index([fk_vozilo])
  @@index([fk_uporabnik])
  @@index([fk_stranka])
}

model LOG_voznja {
  idLOG               Int       @id @default(autoincrement())
  timestamp           DateTime
  TYPE                String    @db.VarChar(255)
  metoda              String?   @db.VarChar(10)
  url                 String?   @db.VarChar(255)
  voznja_id_voznja    Int       @default(0)
  voznja_fk_uporabnik Int
  uporabnik           Uporabnik @relation(fields: [voznja_fk_uporabnik], references: [id_uporabnik])

  @@index([voznja_fk_uporabnik])
  @@index([timestamp])
}


model TahografZapis {
  id_zapis        Int       @id @default(autoincrement())
  fk_uporabnik    Int
  stanje          String    @db.VarChar(20)
  zacetek         DateTime
  konec           DateTime?
  trajanje_min    Int?
  lokacija_zac    String?   @db.VarChar(100)
  lokacija_kon    String?   @db.VarChar(100)
  registrska      String?   @db.VarChar(20)
  posadka         Boolean   @default(false)
  vir             String    @default("POSNETO") @db.VarChar(20)
  timestamp_zapis DateTime  @default(now())
  uporabnik       Uporabnik @relation(fields: [fk_uporabnik], references: [id_uporabnik])

  @@index([fk_uporabnik])
  @@index([stanje])
  @@index([vir])
  @@map("tahograf_zapis")
}
